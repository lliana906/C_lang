#include <stdio.h>

int main()
{   
    int red = 1;  //변수를 4 byte로 공간을 할당해준다.
    printf ("red1: %d\n", red);   //1이라는 결과가 출력이 된다.

    red = 2; // 이미 공간을 할당 했기 때문에 int를 또 붙일 필요 없다. 값 변경 가능
    printf ("red2: %d\n", red); 

    {
         red = 3;
        printf ("red3: %d\n", red);  
    }

    printf ("red: %d\n", red);

    

    return 0; 
     
}
//블럭이 있지만 공간할당이 없으면 같은걸로 본다.  

