//전역 변수

int yellow =10;  

int main()
{   
    int red = 1;  //변수를 4 byte로 공간을 할당해준다.
    printf ("red1: %d\n", red);   //1이라는 결과가 출력이 된다.

    printf ("yellow: %d\n",yellow);

    yellow =3; //안에서 바꾸기 가능 

    printf ("red: %d\n", red);
    printf ("yellow: %d\n",yellow);

    return 0; 
     
}

