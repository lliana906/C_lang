//선언과 할당
int main()
{   int green; //선언

    int red = 1;  //변수를 4 byte로 공간을 할당해준다.
    printf ("red1: %d\n", red);   //1이라는 결과가 출력이 된다.

    green = 8; //할당 
    //같이 이루어져도되고 따로 해도됨 근데 할당작업이 필수로 필요하긴 함 
    printf ("red1: %d\n", green);

    return 0; 
     
}
